# Copy this file to .env and update values for your setup

# Backend API URL (where your Node.js server runs)
VITE_API_URL=http://localhost:5000/api

# Public base URL for customer-facing links (WhatsApp, QR codes)
# In development this auto-detects as http://localhost:5173
# In production set this to your actual domain:
# VITE_PUBLIC_BASE_URL=https://mrlodge.yourdomain.com
VITE_PUBLIC_BASE_URL=
